# Configuración de Firebase (copia este archivo a .env.local y rellena los valores).
# Los valores están en: Consola de Firebase → Configuración del proyecto → Tus apps → App web.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Strava (Hito 8): crea una app en https://www.strava.com/settings/api
# El "Authorization Callback Domain" debe ser el dominio desde el que uses
# la app (el de Vercel en producción; localhost o el del Codespace en dev).
NEXT_PUBLIC_STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
