rules_version = '2';

// Reglas de PeakTrail: pégalas en la consola de Firebase
// (Firestore Database → Reglas) cuando quieras cerrar el modo de prueba.
// El roster de amigos se gestiona con `npm run amigos:anadir -- email`
// ANTES de aplicar estas reglas (después, desde la app como propietario/admin,
// o desde la consola). El email del propietario es una constante fija (sin
// ruta en la app para crearlo): si cambia, edítalo aquí Y en
// src/lib/propietario.ts.
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null && request.auth.token.email != null;
    }

    function esPropietario() {
      return autenticado() && request.auth.token.email == "josemiangos@gmail.com";
    }

    // En el roster global de amigos, o el propietario. El sign-in de Google
    // no está restringido a un dominio, así que esto es lo único que
    // distingue a alguien del grupo cerrado de cualquier cuenta de Google.
    function esAmigo() {
      return esPropietario() ||
        (autenticado() &&
          exists(/databases/$(database)/documents/amigos/$(request.auth.token.email)));
    }

    // Admin del roster de amigos y de los grupos (campo admin: true en su
    // propio doc de `amigos`), o el propietario.
    function esAdmin() {
      return esPropietario() ||
        (esAmigo() &&
          get(/databases/$(database)/documents/amigos/$(request.auth.token.email)).data.admin == true);
    }

    function miembroDeGrupo(grupoId) {
      return autenticado() &&
        exists(/databases/$(database)/documents/grupos/$(grupoId)) &&
        request.auth.token.email in
          get(/databases/$(database)/documents/grupos/$(grupoId)).data.miembros;
    }

    // Catálogo: lectura pública, escritura solo por importación (consola/scripts con reglas abiertas)
    match /elementos/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Roster global de amigos: cualquier amigo puede leer a los demás (hace
    // falta para resolver nombre/uid de los compañeros de grupo al marcar
    // participantes; el documento no lleva nada sensible). Solo el
    // propietario puede tocar el campo `admin`: un admin no propietario
    // crea/edita amigos pero nunca asciende ni desciende a nadie. Cada uno
    // puede autorregistrar su propio uid/nombre (para que le puedan
    // etiquetar como participante), nunca el campo `admin`.
    match /amigos/{email} {
      allow read: if esAmigo();
      allow create: if esPropietario() || (esAdmin() && request.resource.data.admin == false);
      allow update: if esPropietario() ||
        (esAdmin() && request.resource.data.admin == resource.data.admin) ||
        (autenticado() && request.auth.token.email == email &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["uid", "nombre"]) &&
          request.resource.data.uid == request.auth.uid);
      allow delete: if esAdmin() && request.auth.token.email != email;
    }

    // Grupos: cualquier admin/propietario crea, renombra, gestiona
    // miembros y borra cualquier grupo (rol admin global, no por grupo,
    // dado el círculo pequeño y de confianza). Un miembro normal solo lee
    // los grupos a los que pertenece.
    match /grupos/{grupoId} {
      allow read: if esAdmin() || (autenticado() && request.auth.token.email in resource.data.miembros);
      allow create, update, delete: if esAdmin();
    }

    // Rutas planificadas: compartidas dentro del grupo al que pertenecen
    match /planes/{id} {
      allow read: if miembroDeGrupo(resource.data.grupoId);
      allow create: if miembroDeGrupo(request.resource.data.grupoId);
      allow update, delete: if miembroDeGrupo(resource.data.grupoId);
    }

    // Registro de realizados: con grupo (grupoId no nulo), todo el grupo lo
    // ve; individual (grupoId nulo), solo el propio autor puede leerlo.
    // Al crear uno de grupo, cualquier miembro puede hacerlo a nombre de
    // cualquier uid (para etiquetar participantes): no se verifica que ese
    // uid sea realmente de alguien del grupo (las reglas no pueden buscar
    // qué email es dueño de un uid, solo leer por ruta conocida) — mismo
    // criterio ya aceptado en comentarios/fotos para esta escala de grupo
    // pequeño y de confianza. Editar/borrar siempre exige ser el dueño real
    // del documento, así que cada uno gestiona solo el suyo.
    match /realizados/{id} {
      allow read: if (resource.data.grupoId != null && miembroDeGrupo(resource.data.grupoId)) ||
        (autenticado() && resource.data.usuario == request.auth.uid);
      allow create: if
        (request.resource.data.grupoId == null &&
          request.resource.data.usuario == request.auth.uid && esAmigo()) ||
        (request.resource.data.grupoId != null &&
          miembroDeGrupo(request.resource.data.grupoId));
      allow update: if resource.data.usuario == request.auth.uid &&
        request.resource.data.usuario == request.auth.uid &&
        (
          (request.resource.data.grupoId == null && esAmigo()) ||
          (request.resource.data.grupoId != null && miembroDeGrupo(request.resource.data.grupoId))
        );
      allow delete: if autenticado() && resource.data.usuario == request.auth.uid;
    }

    // Fotos y comentarios del grupo: todo el grupo lee, cada uno borra lo suyo
    match /comentarios/{id} {
      allow read: if miembroDeGrupo(resource.data.grupoId);
      allow create: if miembroDeGrupo(request.resource.data.grupoId) &&
        request.resource.data.usuario == request.auth.uid;
      allow delete: if miembroDeGrupo(resource.data.grupoId) &&
        resource.data.usuario == request.auth.uid;
    }
    match /fotos/{id} {
      allow read: if miembroDeGrupo(resource.data.grupoId);
      allow create: if miembroDeGrupo(request.resource.data.grupoId) &&
        request.resource.data.usuario == request.auth.uid;
      allow delete: if miembroDeGrupo(resource.data.grupoId) &&
        resource.data.usuario == request.auth.uid;
    }
  }
}
